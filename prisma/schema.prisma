datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String?  @unique
  gender          String   // masculino | feminino
  birthDate       DateTime
  height          Float    // cm
  weight          Float    // kg
  bodyFatPercent   Float?
  activityLevel   String   // sedentario | leve | moderado | ativo | muito_ativo
  goal            String   // perder | manter | ganhar
  goalKgPerWeek   Float    @default(0.5)
  dailyCalTarget  Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mealEntries     MealEntry[]
  exerciseEntries ExerciseEntry[]
  weightLogs      WeightLog[]
  dailyLogs       DailyLog[]
  fixedFoods      FixedFood[]
  streak          Streak?
}

model Food {
  id           String   @id @default(cuid())
  name         String
  brand        String?
  category     String   // frutas | carnes | graos | laticinios | legumes | paes | bebidas | refeicoes | industrializados | oleos
  servingSize  Float    // grams
  servingLabel String   // "100g", "1 unidade", "1 fatia"
  calories     Float
  protein      Float    // g
  carbs        Float    // g
  fat          Float    // g (gordura total)
  saturatedFat Float    @default(0) // g (gordura saturada)
  transFat     Float    @default(0) // g (gordura trans)
  fiber        Float    @default(0) // g
  sugar        Float    @default(0) // g
  sodium       Float    @default(0) // mg
  noomColor    String   // green | yellow | orange
  isCustom     Boolean  @default(false)
  createdAt    DateTime @default(now())

  isCombo      Boolean  @default(false)

  mealEntries MealEntry[]
  fixedFoods  FixedFood[]
  comboItems  ComboItem[]
}

model ComboItem {
  id        String @id @default(cuid())
  comboId   String // Food.id do combo pai
  foodId    String // Food.id do ingrediente
  quantity  Float  // quantidade em gramas ou unidades
  unit      String // "g", "unidade", "pitada", "colher"
  servings  Float  @default(1) // porcoes do ingrediente

  combo Food @relation(fields: [comboId], references: [id], onDelete: Cascade)

  @@index([comboId])
}

model MealEntry {
  id        String   @id @default(cuid())
  userId    String
  foodId    String
  date      String   // ISO date "2026-03-31"
  mealType  String   // cafe_da_manha | almoco | jantar | lanche
  servings  Float    @default(1)
  calories  Float    // denormalized
  protein   Float
  carbs     Float
  fat       Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  food Food @relation(fields: [foodId], references: [id])

  @@index([userId, date])
}

model Exercise {
  id                String   @id @default(cuid())
  name              String
  category          String   // cardio | musculacao | esportes | flexibilidade | funcional
  caloriesPerMinBase Float   // for 70kg person
  icon              String?  // emoji
  createdAt         DateTime @default(now())

  exerciseEntries ExerciseEntry[]
}

model ExerciseEntry {
  id             String   @id @default(cuid())
  userId         String
  exerciseId     String
  date           String
  durationMin    Int
  caloriesBurned Float
  createdAt      DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([userId, date])
}

model WeightLog {
  id             String   @id @default(cuid())
  userId         String
  date           String
  weight         Float
  bodyFatPercent  Float?
  note           String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model DailyLog {
  id               String   @id @default(cuid())
  userId           String
  date             String
  caloriesTarget   Int
  caloriesConsumed Float    @default(0)
  caloriesBurned   Float    @default(0)
  protein          Float    @default(0)
  carbs            Float    @default(0)
  fat              Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model FixedFood {
  id        String @id @default(cuid())
  userId    String
  foodId    String
  mealType  String   // cafe_da_manha | almoco | jantar | lanche | qualquer
  servings  Float    @default(1)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  food Food @relation(fields: [foodId], references: [id])

  @@index([userId])
}

model Streak {
  id             String  @id @default(cuid())
  userId         String  @unique
  currentStreak  Int     @default(0)
  longestStreak  Int     @default(0)
  lastLogDate    String?

  user User @relation(fields: [userId], references: [id])
}
